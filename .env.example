# 通用大模型配置（推荐用这套变量名）
# - OpenAI：LLM_PROVIDER=openai，LLM_BASE_URL 留空即可
# - 阿里云百炼 / 通义千问：LLM_PROVIDER=dashscope，LLM_BASE_URL 默认北京；也可改新加坡/美国
LLM_PROVIDER=dashscope
LLM_API_KEY=sk-2c09c0f9deee46d68646b561787c7b91
LLM_MODEL=qwen-turbo
# 可选：默认北京
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 兼容旧变量（也可用，但建议迁移到 LLM_*）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
